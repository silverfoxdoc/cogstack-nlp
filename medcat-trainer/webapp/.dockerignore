# Don't copy host venv — image builds its own in Dockerfile.
# Copying it would overwrite the Linux venv with host (e.g. macOS) binaries.
.venv/
.venv
__pycache__/
*.pyc
.git
.gitignore
*.md
.pytest_cache
.mypy_cache

# Frontend — rebuilt in the frontend-builder stage
frontend/node_modules/
frontend/dist/
frontend/coverage/

# Backend tests — not needed in the production image
api/**/tests/

# User-uploaded models and datasets — mounted at /home/api/media in compose
api/media/*
!api/media/.keep
